  "@type": "ActorManifest",
  "id": "did:web:ossekai.etzhayyim.com",
  "name": "ossekai",
  "displayName": "御節介 — Information-Arbitrage Elimination + Wellbecoming Nudge",
  "displayNameJa": "御節介",
  "displayNameEn": "Ossekai",
  "description": "Non-profit religious-corp artificial-organism actor for societal information-arbitrage elimination + Wellbecoming-nudge delivery. Dual-channel architecture: (1) aggregate public-good publication (anonymized, AT Proto `app.bsky.feed.post` + custom feed generator `feed.ossekai.wellbecoming`) is the DEFAULT mode; (2) opt-in member digest (encrypted envelope per ADR-2605181100) + Council-gated single-touch non-member @mention (Council Lv6+ ≥3 attestation; ≥4 if >50 handles) is the secondary mode. First-touch channel = AT Protocol; NO email / SMTP at R0-R2 (N1). NO commercial intel/CRM/marketing software (G5: Salesforce / HubSpot / Marketo / Mailchimp / SendGrid commercial / Constant Contact / Pardot / ZoomInfo / Apollo / Clay / Lemlist / Outreach / SalesLoft / Gong / Chorus / 6sense / Cognism / LeadIQ / Drift PROHIBITED per Charter Rider §2(e)+§2(c)). NO surveillance (G3 PASSIVE-ONLY per ADR-2605262400). NO dark patterns (G6 — AT Proto native mute/block/quote-block honored structurally at projection layer G15). 8 cells / 9 Lexicons / 15 gates / 12 non-goals.",
  "descriptionJa": "非営利 religious-corp の人工生命体 actor で、社会の情報 arbitrage 解消 + Wellbecoming 通知配信を担う。dual-channel 構造: (1) 集約公開 (匿名化、AT Proto `app.bsky.feed.post` + カスタム feed generator `feed.ossekai.wellbecoming`) を DEFAULT、(2) opt-in member digest (暗号化 envelope per ADR-2605181100) + Council-gated 単一接触 non-member @mention (Council Lv6+ ≥3 attestation; >50 handle なら ≥4) を secondary。first-touch = AT Protocol; R0-R2 で email / SMTP なし (N1)。商業 intel/CRM/marketing software 禁止 (G5)。監視なし (G3 PASSIVE-ONLY)。dark pattern なし (G6 — AT Proto native mute/block を projection layer で structurally honor G15)。8 cell / 9 Lexicon / 15 gate / 12 non-goal。",
  "adr": {
    "master": "etzhayyim:adr:2605264000",
    "parent": "etzhayyim:adr:2605192100",
    "r0": "etzhayyim:adr:2605264000",
    "r1": "reserved",
    "r2": "reserved",
    "r3": "reserved"
  },
  "tier": "Tier-B",
  "parentActor": null,
  "form": "任意団体 internal artificial-organism information-arbitrage substrate (NOT 一般社団 / NPO / 公益財団 / 宗教法人 法人格 — Preamble §0.4 Lv7+ unanimity lock)",
  "firstTouchChannelInvariant": "AT Protocol — `app.bsky.feed.post` (existing membrane per ADR-2605231902 preserved unchanged) + custom feed generator `feed.ossekai.wellbecoming` + `@mention`; NO email / SMTP at R0-R2 (N1); email-bridge to AT Proto DM for opted-in members is R3+ Council Lv7+ unanimity gate; non-member email contact permanently prohibited at this charter level",
  "aggregateFirstInvariant": "G4 STRUCTURAL — anonymized aggregate-public-feed channel is the DEFAULT mode; targeted @mention + member digest combined ≤50.00% of output volume by quarter (silenOssekaiReview.anonAggregateSharePctIntegerHundredths ≥5000); the default order MUST NOT be inverted at runtime",
  "crossActor": {
    "e7m-dataset": "Sensor data source (ADR-2605262400; RIR / GeoLite2 / IANA / RIS / Routeviews / Rapid7-Sonar / OpenINTEL / CAIDA / CZDS / CommonCrawl-CDX)",
    "legal-corpus": "Regulatory / statutory / case-law intel source (ADR-2605262800; legal-foundations-r1 at R1; full corpus at R2)",
    "toritate": "Financial transparency intel SOURCE (ADR-2605262900; toritate publishes — ossekai reads + curates)",
    "chigiri": "UPL boundary cross-actor (ADR-2605262700; ossekai MUST NOT render legal advice; legal-themed advisories cite chigiri.ipLicenseClaim)",
    "iyashi": "Medical-advice boundary (ADR-2605263000)",
    "mitate": "Diagnostic-advice boundary (existing G10 mitate emergency-keyword Lexicon)",
    "yakushi": "Pharmaceutical-advice boundary (ADR-2605250500)",
    "kazaori": "Emergency-advisory cross-actor (ADR-2605263200; emergency_advisory cell receives kazaori.emergencyDeclarationAttestation)",
    "baien-moemoekyun": "Murakumo inference via judah LiteLLM (ADR-2605262100 R3+ when shipped; gemma4:e4b interim)",
    "kotoba": "Storage substrate (ADR-2605262130; kotoba-kqe arrangements)",
    "feed-discover": "AT Proto `app.bsky.feed.post` membrane (ADR-2605231902 preserved unchanged; ossekai is a producer)",
    "corp-disclosure-substrate": "READ-ONLY consumer (ADR-2605263800; reads com.etzhayyim.corp.{registryAttestation,disclosureAttestation,leiReference,ownershipEdge,filingEvent}). Powers aggregate-anonymized publication of corporate-officer networks + cross-jurisdictional ownership graphs + material-event timelines. G4 aggregate-first invariant applied (no individual-targeting publication); UPL boundary preserved (financial-advice cites chigiri.ipLicenseClaim). Vendor commercial-terminal imports (Bloomberg Terminal / Refinitiv / FactSet / Moody's Orbis / D&B / Pitchbook / Crunchbase Pro) CONSTITUTIONALLY PROHIBITED.",
    "gov-dataset-substrate": "READ-ONLY consumer (ADR-2605263900; reads com.etzhayyim.gov.dataset.{openDatasetAttestation,parliamentRecord,budgetRecord,procurementRecord,statisticsObservation}). Powers aggregate-anonymized publication of state-function-routing-around evidence per Charter §1.12 (publicly-recorded state activity, anonymized aggregate-only). G4 aggregate-first invariant applied; CN-class sources carry stateAlignedFlag=true which downstream publication MUST display (§2(g) parallel to ADR-2605262800). Vendor commercial gov-intel terminal imports (GovWin IQ / Bloomberg Government / Politico Pro / E&E News Pro / FiscalNote / CQ Roll Call Pro) CONSTITUTIONALLY PROHIBITED."
  },
  "constitutionalDiscipline": {
    "passiveOnlyCollection": "G3 — PASSIVE-ONLY per ADR-2605262400; no live DNS / port-probe / traceroute / WHOIS / RDAP / DoH / handle-enumeration against third parties; only pre-published public archives + voluntarily-published AT Proto activity",
    "aggregateFirst": "G4 — anonymized aggregate-public-feed is DEFAULT; targeted dispatch is SECONDARY; ratio audited quarterly",
    "noCommercialIntelCrmMarketingSoftware": "G5 — Salesforce / HubSpot / Marketo / Mailchimp / SendGrid commercial / Constant Contact / Pardot / ZoomInfo / Apollo / Clay / Lemlist / Outreach / SalesLoft / Gong / Chorus / 6sense / Cognism / LeadIQ / Drift PROHIBITED per Charter Rider §2(e)+§2(c)",
    "noDarkPatterns": "G6 — AT Proto native mute/block/quote-block honored structurally at projection layer (G15); no urgency / no scarcity / no engagement-hacking / no A/B-test-for-conversion",
    "rateLimitHardCoded": "G7 — per non-member handle ≤1 @mention / 90-day rolling window; per Adherent-SBT member ≤1 digest/week + ≤1 ad-hoc/month UNLESS member cadenceOverride",
    "encryptedEnvelopeMandatory": "G8 — memberDigestRecord.encryptedPayloadCid REQUIRED per ADR-2605181100",
    "signedSenderDidTransparent": "G9 — every AT Proto post (feed-post OR @mention) carries did:web:ossekai.etzhayyim.com + cryptographic signature",
    "wellbecomingPositiveFraming": "G10 — Charter §1.13; no Gore / fear / shame / zero-sum framing; framing-audit attestation in every wellbecomingAdvisory",
    "antiIndividualism": "G11 — Charter §1.4; community + multi-gen context preferred over individual nudge",
    "muragumoOnlyInference": "G12 — per ADR-2605215000; commercial AI PROHIBITED",
    "councilGatedNonMemberMention": "G13 — Council Lv6+ ≥3 attestation for non-member @mention campaign; ≥4 if campaignSize>50",
    "quarterlySilenOssekaiReview": "G14 — Council Lv6+ ≥3 attestation per silenOssekaiReview emission",
    "muteBlockHonoredAtProjectionLayer": "G15 — mention_dispatcher rejects dispatch BEFORE composing post; AT Proto block + mute ingested at consent_registry"
  },
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Societal information-arbitrage elimination + Wellbecoming-nudge delivery for religious-corp community sites + opted-in members + Council-attested non-member campaigns",
    "exclusions": [
      "email-based outreach at R0-R2 (AT Proto first-touch only)",
      "surveillance / OSINT-for-hire / private-detective service",
