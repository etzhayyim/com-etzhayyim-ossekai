  "constitutionalGates": {
    "description": "15 immutable gates per ADR-2605264000. Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "Charter Rider §2(a)-(h) scan on every input AND output",
      "G2": "kotoba-datomic attestation lineage on every record",
      "G3": "PASSIVE-ONLY collection (no live DNS / probe / traceroute / WHOIS / RDAP / DoH / handle-enumeration; pre-published public archives + voluntary AT Proto activity only)",
      "G4": "Aggregate-first publication (anonymized AT Proto feed-post DEFAULT; targeted dispatch SECONDARY; ratio audited quarterly ≥50%)",
      "G5": "NO commercial intel / CRM / marketing software (Salesforce / HubSpot / Marketo / Mailchimp / SendGrid commercial / Constant Contact / Pardot / ZoomInfo / Apollo / Clay / Lemlist / Outreach / SalesLoft / Gong / Chorus / 6sense / Cognism / LeadIQ / Drift PROHIBITED)",
      "G6": "NO dark patterns (AT Proto native mute/block/quote-block honored at projection layer G15; no urgency / scarcity / engagement-hacking / A/B-test-for-conversion)",
      "G7": "Rate limit hard-coded (non-member ≤1/90d/handle; member ≤1 digest/week + ≤1 ad-hoc/month default)",
      "G8": "Encrypted envelope MANDATORY for member digest (ADR-2605181100)",
      "G9": "Signed sender DID transparent (did:web:ossekai.etzhayyim.com + cryptographic signature on every post)",
      "G10": "Wellbecoming-positive framing only (Charter §1.13; framing-audit attestation in every advisory)",
      "G11": "Anti-individualism (Charter §1.4; community + multi-gen context preferred)",
      "G12": "Murakumo-only inference (ADR-2605215000)",
      "G13": "Council Lv6+ ≥3 attestation for non-member @mention campaign (≥4 if campaignSize>50)",
      "G14": "silenOssekaiReview quarterly audit",
      "G15": "AT Proto native mute/block honored at projection layer (mention_dispatcher rejects dispatch BEFORE composing post)"
    }
  },
