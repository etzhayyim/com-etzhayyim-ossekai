;; ossekai 御節介 — arbitrage_observer cell (langgraph, wasm runtime)
;; ADR-2605264000 — maps to py/agent.py handle_arbitrage_observer
{:cell/id "arbitrage_observer"
 :cell/glyph "御節介"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_arbitrage_observer"
 :cell/doc "Detect INFORMATION-asymmetry pockets — beneficial public facts (rights/refunds/free services/deadlines) that exist but are buried beneath legalese/paywalls/dispersed sources. PASSIVE-ONLY (G3): consumes pre-published archives + voluntary AT Proto only; NO live DNS/probe/WHOIS/handle-enum. Emits arbitrageGapReport."
 :cell/gates ["G1" "G2" "G3"]
 :cell/kotoba
 {:reads [:info.item/topic :info.item/benefit :info.item/accessibility :info.item/source-class :info.item/public-right]
  :writes [:arb.gap/topic :arb.gap/score :arb.gap/notable :arb.gap/shape :arb.gap/source-class]}}
