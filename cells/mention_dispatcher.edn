;; ossekai 御節介 — mention_dispatcher cell (langgraph, wasm runtime)
;; ADR-2605264000 — maps to py/agent.py handle_mention_dispatcher
{:cell/id "mention_dispatcher"
 :cell/glyph "御節介"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_mention_dispatcher"
 :cell/doc "The SECONDARY, Council-gated targeted path (aggregate_publisher is the default). Composes a non-member @mention ONLY when: Council Lv6+ ≥3 attestation (≥4 if >50 handles, G13); EITHER a member-impact attestation OR a valid per-recipient externalMentionConsent; the handle is NOT blocked/muted (G15, checked BEFORE composing — the post never enters MST); and the ≤1/90d/handle rate budget holds (G7). Broadcast operator-gated; default :draft (no-server-key)."
 :cell/gates ["G1" "G6" "G7" "G9" "G13" "G15"]
 :cell/lexicon "app.bsky.feed.post"
 :cell/kotoba
 {:reads [:consent.state/handle :consent.state/blocked :consent.state/muted :consent.state/consent-valid
          :arb.gap/topic]
  :writes [:mention.dispatch/handle :mention.dispatch/state :mention.dispatch/attestation]}}
