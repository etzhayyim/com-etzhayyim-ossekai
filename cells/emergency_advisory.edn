;; ossekai 御節介 — emergency_advisory cell (langgraph, wasm runtime; paired-kazaori)
;; ADR-2605264000 — maps to py/agent.py handle_emergency_advisory
{:cell/id "emergency_advisory"
 :cell/glyph "御節介"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_emergency_advisory"
 :cell/doc "Expedited Wellbecoming-positive advisory triggered ONLY by a valid kazaori emergencyDeclarationAttestation (cross-actor). Bypasses normal cadence but keeps every other gate: G10 NO fear-amplification (calm, actionable framing — fear/panic vocabulary is refused), G1 Charter-Rider-clean, aggregate-first shape (G4), signed sender DID (G9). Without a valid attestation it refuses outright (ossekai cannot self-declare an emergency). Broadcast operator-gated (no-server-key)."
 :cell/gates ["G1" "G4" "G9" "G10"]
 :cell/lexicon "app.bsky.feed.post"
 :cell/kotoba
 {:reads [:emergency/attestation-valid :emergency/declarer :advisory/topic :advisory/text]
  :writes [:emergency.post/text :emergency.post/expedited :emergency.post/state]}}
