;; ossekai 御節介 — member_digest cell (langgraph, wasm runtime; paired-PDS)
;; ADR-2605264000 — maps to py/agent.py handle_member_digest
{:cell/id "member_digest"
 :cell/glyph "御節介"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_member_digest"
 :cell/doc "Weekly encrypted digest to opted-in Adherent-SBT members. G8: the payload is ALWAYS an com.etzhayyim.encrypted.* envelope (XChaCha20-Poly1305, Signal-wrapped, DID-bound; ADR-2605181100) — plaintext PII NEVER crosses the boundary. ≤500 opt-in roster cap; ≤1 digest/week (+≤1 ad-hoc/month) per member; member must be an active SBT holder who opted in, with per-category granularity. Aggregate-first still holds (this is opt-in delivery, not targeting). Broadcast operator-gated (no-server-key)."
 :cell/gates ["G1" "G8" "G9" "G10"]
 :cell/kotoba
 {:reads [:member/did :member/sbt-active :member/opted-in :member/categories :member/last-digest-at
          :advisory/topic :advisory/category]
  :writes [:digest/recipient-did :digest/envelope-ref :digest/state]}}
