;; ossekai 御節介 — aggregate_publisher cell (langgraph, wasm runtime)
;; ADR-2605264000 — maps to py/agent.py handle_aggregate_publisher
{:cell/id "aggregate_publisher"
 :cell/glyph "御節介"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_aggregate_publisher"
 :cell/doc "Compose an aggregate-first (anonymized) Wellbecoming advisory from arbitrageGapReports and post to AT Proto (app.bsky.feed.post). DEFAULT mode is the anonymized public feed (G4); ≤100 posts/week ceiling (G7); NO dark patterns / urgency / scarcity (G6); Charter-Rider-clean (G1); Wellbecoming-positive framing only (G10); signed sender DID (G9). Live broadcast is operator-gated; default is a :draft (G13/no-server-key)."
 :cell/gates ["G1" "G4" "G6" "G7" "G9" "G10"]
 :cell/lexicon "app.bsky.feed.post"
 :cell/kotoba
 {:reads [:arb.gap/topic :arb.gap/score :arb.gap/notable]
  :writes [:feed.post/text :feed.post/shape :feed.post/signed-did]}}
