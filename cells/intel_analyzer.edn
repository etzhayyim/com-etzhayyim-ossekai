;; ossekai 御節介 — intel_analyzer cell (langgraph, wasm runtime)
;; ADR-2605264000 — maps to py/agent.py handle_intel_analyzer
{:cell/id "intel_analyzer"
 :cell/glyph "御節介"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_intel_analyzer"
 :cell/doc "The middle layer (observer → ANALYZER → publisher). Turns an arbitrageGapReport into a wellbecomingAdvisory: G10 framing audit (no fear/shame/gore/zero-sum — REQUIRED, attestation carried), G11 anti-individualism (community + multi-generational context, not individual-optimizing), G1 Charter-Rider scan, and a REQUIRED cross-actor citation for legal/medical/financial/diagnostic/pharma topics (UPL + clinical + financial-advice boundaries: chigiri/iyashi/mitate/yakushi/toritate). Optional Murakumo narration (G12, no external LLM)."
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G10" "G11" "G12"]
 :cell/kotoba
 {:reads [:arb.gap/topic :arb.gap/score :arb.gap/public-right]
  :writes [:advisory/topic :advisory/text :advisory/framing-audit-passed
           :advisory/cross-actor-citation :advisory/community-context]}}
